# Project configuration
PROJECT_DIR="/Users/bc/brendanchambers/2026-06-18-iphone-video-to-splat"

# Input video (relative path from project root)
VIDEO_PATH="./data/incoming/gardenbed_test_4s_middle.mov"

# Experiment/scene name
EXPERIMENT_NAME="test_4s_scene"

# COLMAP
# <placeholder>

# OpenSplat Training
NUM_ITERS=50

# OpenSplat Validation
# Enable validation mode (witholds single image from training)
VAL_ENABLED=true

# Validation image selection: "random" or specific filename (e.g., "frame_0001.jpg")
VAL_IMAGE="frame_0032.jpg"

# Directory for rendered validation images (saves every 10 training steps)
# Leave empty to disable validation rendering
VAL_RENDER_DIR="./data/intermediates/validation_renders"

# SSIM weight in loss function (0.0-1.0, default 0.2)
# Higher values emphasize perceptual quality, lower emphasize L1 reconstruction
SSIM_WEIGHT=0.2

